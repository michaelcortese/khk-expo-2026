; ============================================================
; HUD — CanvasLayer (screen-space overlay)
; Layout (1280 x 1024 viewport):
;   TimerBar  — full width, 45 px tall, anchored to top
;   BottomBar — full width, 220 px tall, anchored to bottom
;     P1Panel (left 50%):  VBox → [P1Cards HBox] + [P1ElixirBar]
;     P2Panel (right 50%): VBox → [P2Cards HBox RTL] + [P2ElixirBar]
;     DoubleElixirBadge — centred, hidden until 1:00 remaining
; ============================================================

[node name="HUD" type="CanvasLayer" unique_id=710024051]
script = ExtResource("3")

; ---------- Root control (full viewport) ----------
[node name="Root" type="Control" parent="." unique_id=128783027]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
mouse_filter = 2

; ---------- Timer bar — top strip ----------
[node name="TimerBar" type="ColorRect" parent="Root" unique_id=2200000001]
